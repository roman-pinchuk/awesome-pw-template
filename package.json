{
  "name": "awesome-pw-template",
  "version": "1.0.0",
  "description": "Senior-level Playwright TypeScript template for UI and API automation",
  "packageManager": "npm@11.11.0",
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "api-testing",
    "test-automation",
    "template"
  ],
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=chromium --headed",
    "test:debug": "playwright test --project=chromium --debug",
    "test:ui:mode": "playwright test --ui --ui-host=0.0.0.0 --ui-port=9323",
    "verify:playwright": "node scripts/verify-playwright-version.mjs",
    "test:ci": "dotenvx run -f .env.production -- playwright test",
    "test:ui:ci": "dotenvx run -f .env.production -- playwright test --project=chromium --project=firefox --project=webkit",
    "test:api:ci": "dotenvx run -f .env.production -- playwright test --project=api",
    "report": "playwright show-report",
    "prepare": "simple-git-hooks",
    "prettier": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc",
    "check": "npm run verify:playwright && npm run lint && npm run typecheck"
  },
  "author": "Roman Pinchuk",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.1.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.0",
    "@types/pino": "^7.0.4",
    "allure-playwright": "^3.10.2",
    "eslint": "^10.1.0",
    "eslint-plugin-playwright": "^2.10.1",
    "lint-staged": "^17.0.8",
    "playwright-ctrf-json-reporter": "^0.0.29",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.2",
    "zod": "^4.4.3"
  },
  "private": true,
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,jsonc,md,yml,yaml}": "prettier --write"
  }
}
