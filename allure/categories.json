[
  {
    "name": "Product defects",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*expected.*|.*assert.*|.*should.*|.*to be.*|.*toEqual.*|.*toContain.*"
  },
  {
    "name": "Test defects",
    "matchedStatuses": ["broken"]
  },
  {
    "name": "Infrastructure issues",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*timeout.*|.*Timeout.*|.*connection.*|.*refused.*|.*ENOTFOUND.*|.*ECONNREFUSED.*|.*ECONNRESET.*|.*ETIMEDOUT.*|.*socket hang up.*"
  },
  {
    "name": "Known issues",
    "matchedStatuses": ["known"]
  }
]
